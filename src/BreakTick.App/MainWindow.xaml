<Window x:Class="BreakTick.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="BreakTick" Height="680" Width="420" WindowStartupLocation="CenterScreen"
        Background="{StaticResource SurfaceBrush}">
    <Grid Margin="32">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <StackPanel>
            <TextBlock Text="BreakTick" FontSize="22" FontWeight="SemiBold" />
            <TextBlock Text="留一点时间给身体和眼睛" Foreground="{StaticResource MutedBrush}" Margin="0,6,0,0" />
        </StackPanel>
        <StackPanel Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center">
            <Border Width="196" Height="196" BorderThickness="8" BorderBrush="{StaticResource AccentBrush}" CornerRadius="98">
                <StackPanel VerticalAlignment="Center">
                    <TextBlock x:Name="PhaseText" TextAlignment="Center" Foreground="{StaticResource MutedBrush}" FontSize="14" />
                    <TextBlock x:Name="TimeText" TextAlignment="Center" FontSize="46" FontWeight="SemiBold" Margin="0,8" />
                </StackPanel>
            </Border>
            <TextBlock x:Name="ProgressText" TextAlignment="Center" Margin="0,20,0,0" Foreground="{StaticResource MutedBrush}" />
            <TextBlock x:Name="StatsText" TextAlignment="Center" Margin="0,8,0,0" Foreground="{StaticResource MutedBrush}" FontSize="12" />
            <TextBlock x:Name="WeekText" TextAlignment="Center" Margin="0,4,0,0" Foreground="{StaticResource MutedBrush}" FontSize="12" />
            <TextBlock x:Name="BadgeText" TextAlignment="Center" Margin="0,4,0,0" Foreground="{StaticResource AccentBrush}" FontSize="12" />
        </StackPanel>
        <Grid Grid.Row="2" Margin="0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition />
                <ColumnDefinition />
                <ColumnDefinition />
            </Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock Text="工作（分钟）" Foreground="{StaticResource MutedBrush}" FontSize="12" />
                <TextBox x:Name="WorkMinutesBox" Margin="0,6,10,0" Padding="8,6" />
            </StackPanel>
            <StackPanel Grid.Column="1">
                <TextBlock Text="休息（秒）" Foreground="{StaticResource MutedBrush}" FontSize="12" />
                <TextBox x:Name="BreakSecondsBox" Margin="0,6,10,0" Padding="8,6" />
            </StackPanel>
            <StackPanel Grid.Column="2">
                <TextBlock Text="每日目标" Foreground="{StaticResource MutedBrush}" FontSize="12" />
                <TextBox x:Name="DailyGoalBox" Margin="0,6,0,0" Padding="8,6" />
            </StackPanel>
        </Grid>
        <StackPanel Grid.Row="3" Margin="0,0,0,16">
            <TextBlock Text="休息提示位置" Foreground="{StaticResource MutedBrush}" FontSize="12" />
            <ComboBox x:Name="PositionBox" SelectedValuePath="Tag" Margin="0,6,0,0" Padding="8,6">
                <ComboBoxItem Tag="TopRight">右上角卡片</ComboBoxItem>
                <ComboBoxItem Tag="TopLeft">左上角卡片</ComboBoxItem>
                <ComboBoxItem Tag="Center">屏幕中央</ComboBoxItem>
                <ComboBoxItem Tag="FullScreen">全屏休息提示</ComboBoxItem>
            </ComboBox>
            <CheckBox x:Name="ResetOnUnlockCheck" Content="解锁后重新开始工作计时" Margin="0,12,0,0" />
            <TextBlock Text="快捷键 Ctrl + Alt + B：暂停或继续" Foreground="{StaticResource MutedBrush}" FontSize="12" Margin="0,8,0,0" />
            <CheckBox x:Name="WorkHoursEnabledCheck" Content="只在工作时间提醒" Margin="0,12,0,0" />
            <CheckBox x:Name="LaunchAtLoginCheck" Content="登录 Windows 时自动启动" Margin="0,8,0,0" />
            <CheckBox x:Name="SoundEnabledCheck" Content="休息开始时播放提示音" Margin="0,8,0,0" />
            <CheckBox x:Name="FullScreenAllDisplaysCheck" Content="全屏休息时覆盖所有显示器" Margin="0,8,0,0" />
            <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                <TextBox x:Name="WorkStartBox" Width="80" Padding="8,6" />
                <TextBlock Text="至" VerticalAlignment="Center" Margin="8,0" Foreground="{StaticResource MutedBrush}" />
                <TextBox x:Name="WorkEndBox" Width="80" Padding="8,6" />
            </StackPanel>
        </StackPanel>
        <StackPanel Grid.Row="4" HorizontalAlignment="Center">
            <TextBlock x:Name="SettingsMessage" Foreground="#B76B23" TextAlignment="Center" Margin="0,0,0,8" />
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
            <Button x:Name="PauseButton" Click="Pause_Click" Background="{StaticResource AccentBrush}" Foreground="White" BorderThickness="0" />
            <Button Content="重新开始" Click="Reset_Click" Margin="12,0,0,0" Background="Transparent" BorderBrush="#D7E1DB" />
                <Button Content="保存设置" Click="SaveSettings_Click" Margin="12,0,0,0" Background="Transparent" BorderBrush="#D7E1DB" />
                <Button Content="导出数据" Click="Export_Click" Margin="12,0,0,0" Background="Transparent" BorderBrush="#D7E1DB" />
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>
